# Backend environment variables
# Copy this to .env for local development.
# In production, set the same values in your Google Cloud runtime.
# Never commit real secrets.

PORT=8080
NODE_ENV=production

MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
JWT_SECRET=<your-jwt-secret>
FRONTEND_URL=http://localhost:3000

# Google Vertex AI Gemma 4
# Local auth uses: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=project-f4cb911b-5b50-4b6e-9d6
GOOGLE_VERTEX_LOCATION=global
GOOGLE_VERTEX_MODEL=gemma-4-26b-a4b-it-maas

# Set true for offline development fixtures; false calls Gemma 4 on Vertex AI.
USE_MOCK_AGENTS=false

# Map Generation
# Keep false: frontend renders hex tiles procedurally.
USE_AI_MAP_GENERATION=false
USE_AI_MAP_BACKGROUND_IMAGE=false
