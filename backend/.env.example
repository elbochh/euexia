# ──────────────────────────────────────────────────────────────────────────────
# Backend environment variables
# Copy this to .env for local development.
# In production, set all of these in:
#   AWS Elastic Beanstalk Console → Environment → Configuration → Software → Environment properties
# NEVER commit the real .env file.
# ──────────────────────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT signing secret (generate a long random string)
JWT_SECRET=<your-jwt-secret>

# Frontend URL for CORS (your Amplify URL, e.g. https://main.abc123.amplifyapp.com)
FRONTEND_URL=https://main.<AMPLIFY_APP_ID>.amplifyapp.com

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_ASR_MODEL=gpt-4o-mini-transcribe
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_MAP_MODEL=gpt-4.1-mini

# ── AWS SageMaker ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>

SAGEMAKER_MEDGEMMA_TEXT_ENDPOINT=medgemma-multimodal-endpoint
SAGEMAKER_MEDGEMMA_IMAGE_ENDPOINT=medgemma-multimodal-endpoint
SAGEMAKER_MEDASR_ENDPOINT=medasr-voice-endpoint
SAGEMAKER_HEAR_ENDPOINT=
SAGEMAKER_MEDSIGLIP_ENDPOINT=
SAGEMAKER_MAP_IMAGE_GEN_ENDPOINT=

# ── AI Provider Selection ────────────────────────────────────────────────────
AI_TEXT_PROVIDER=sagemaker
AI_VISION_PROVIDER=sagemaker
AI_ASR_PROVIDER=sagemaker
AI_IMAGE_GENERATION_PROVIDER=openai
AI_MAP_SPEC_PROVIDER=sagemaker

# ── Mock Mode ────────────────────────────────────────────────────────────────
# Set to "false" in production to use real endpoints
USE_MOCK_AGENTS=false

# ── Map Generation ───────────────────────────────────────────────────────────
# Keep false — frontend renders hex tiles procedurally, AI mapSpec is unused
USE_AI_MAP_GENERATION=false
USE_AI_MAP_BACKGROUND_IMAGE=false
