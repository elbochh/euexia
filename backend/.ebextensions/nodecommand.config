# Tell Elastic Beanstalk which Node version to use and how to start the app.
# Environment variables are set via the EB Console → Configuration → Software
# (never commit secrets to this file).

option_settings:
  aws:elasticbeanstalk:container:nodejs:
    NodeVersion: "20"
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /uploads: uploads
    /maps: maps
