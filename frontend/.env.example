# ──────────────────────────────────────────────────────────────────────────────
# Frontend environment variables
# Copy this to .env.local for local development.
# In production, set these in AWS Amplify Console → App settings → Environment variables
# ──────────────────────────────────────────────────────────────────────────────

# Your Elastic Beanstalk backend URL (no trailing slash, include /api)
# Example: https://euexia-backend.us-east-1.elasticbeanstalk.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api
