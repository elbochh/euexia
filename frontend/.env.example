# ──────────────────────────────────────────────────────────────────────────────
# Frontend environment variables
# In production, set these in AWS Amplify Console → App settings → Environment variables
# ──────────────────────────────────────────────────────────────────────────────

# Server-side only (NOT exposed to browser) — used by Next.js proxy rewrite.
# Set this in Amplify to your EB backend URL (NO /api suffix, NO trailing slash).
# Example: http://euexia-backend-env-1.eba-8trr2mdg.us-east-2.elasticbeanstalk.com
BACKEND_URL=http://localhost:8080

# Only needed for local dev — in production the proxy handles routing.
NEXT_PUBLIC_API_URL=http://localhost:8080/api
